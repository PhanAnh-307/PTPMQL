@model FirstWebMVC.Models.Entities.Student

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Nhập họ và tên</label>
        <input asp-for="FullName" class="form-control" />
        <label>Nhập mã sinh viên</label>
        <input asp-for="StudentCode" class="form-control"/>
        <label>Chọn khoa</label>
        <select asp-for="MaKhoa" class="form-control">
            <option value="">-- Chọn khoa --</option>
            @foreach (var khoa in ViewBag.DanhSachKhoa)
            {
                <option value="@khoa.MaKhoa">@khoa.TenKhoa</option>
            }
        </select>
    </div>

    <button type="submit">Lưu</button>
</form>