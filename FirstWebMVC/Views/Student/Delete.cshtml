@model FirstWebMVC.Models.Entities.Student

<h1>Xác nhận xóa</h1>
<h3>có chắc chắn muốn xóa không?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Mã sinh viên:</dt>
        <dd class="col-sm-10">@Model.StudentCode</dd>

        <dt class="col-sm-2">Họ và tên:</dt>
        <dd class="col-sm-10">@Model.FullName</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="StudentCode" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>